{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vibe Trading",
  "version": "0.1.5",
  "identifier": "ai.vibetrading.desktop",
  "build": {
    "frontendDist": "./console-dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../console-app && pnpm dev"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Vibe Trading",
        "width": 650,
        "height": 880,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg",
      "nsis"
    ],
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/32x32.png"
    ],
    "resources": {
      "../.desktop-build/python-runtime": "python-runtime",
      "../.desktop-build/agent": "agent",
      "../frontend/dist": "frontend/dist",
      "../.desktop-build/agent/.env": "agent/.env",
      "../.desktop-build/VERSION": "VERSION"
    }
  }
}
